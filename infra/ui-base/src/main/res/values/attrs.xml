<resources>

    <!--Shared -->
    <attr name="targetViewId" format="reference" />
    <attr name="cornerRadius" format="dimension" />
    <attr name="strokeColor" format="color" />
    <attr name="strokeWidth" format="dimension" />

    <declare-styleable name="DocumentMaskView">
        <attr name="targetViewId" />
        <attr name="maskColor" format="color" />
    </declare-styleable>

    <declare-styleable name="CaptureTargetView">
        <attr name="shape" format="enum">
            <enum name="oval" value="0" />
            <enum name="rect" value="1" />
        </attr>
        <attr name="cornerRadius" />
        <attr name="strokeColor" />
        <attr name="strokeWidth" />
    </declare-styleable>

    <declare-styleable name="CaptureProgressView">
        <attr name="targetViewId" />
        <attr name="progressColor" format="color" />
        <attr name="chipHeight" format="dimension" />
        <attr name="chipGap" format="dimension" />
        <attr name="chipCount" format="integer" />
        <attr name="chipStrokeColor" format="color" />
        <attr name="chipStrokeWidth" format="dimension" />
        <attr name="progress" format="integer" />
    </declare-styleable>

</resources>
